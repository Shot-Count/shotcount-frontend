{
  "rewrites": [
    {
      "source": "/app/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/app/:path*"
    },
    {
      "source": "/api/v1/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/api/v1/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://shotcount-web-desktop.dosudavy.workers.dev/auth/:path*"
    },
    {
      "source": "/onboarding",
      "destination": "https://shotcount-web-desktop.dosudavy.workers.dev/onboarding"
    },
    {
      "source": "/welcome",
      "destination": "https://shotcount-web-desktop.dosudavy.workers.dev/welcome"
    },
    {
      "source": "/login",
      "destination": "https://shotcount-web-desktop.dosudavy.workers.dev/login"
    },
    {
      "source": "/signup",
      "destination": "https://shotcount-web-desktop.dosudavy.workers.dev/signup"
    },
    {
      "source": "/pricing",
      "destination": "https://shotcount-web-desktop.dosudavy.workers.dev/pricing"
    },
    {
      "source": "/offline",
      "destination": "https://shotcount-web-desktop.dosudavy.workers.dev/offline"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/_next/:path*"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "https://shotcount-web.dosudavy.workers.dev/manifest.webmanifest"
    },
    {
      "source": "/sw.js",
      "destination": "https://shotcount-web.dosudavy.workers.dev/sw.js"
    },
    {
      "source": "/images/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/images/:path*"
    },
    {
      "source": "/icons/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/icons/:path*"
    },
    {
      "source": "/fonts/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/fonts/:path*"
    },
    {
      "source": "/sounds/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/sounds/:path*"
    },
    {
      "source": "/company-logos/:path*",
      "destination": "https://shotcount-web.dosudavy.workers.dev/company-logos/:path*"
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "https://shotcount-web.dosudavy.workers.dev/apple-touch-icon.png"
    },
    {
      "source": "/apple-touch-icon-v2.png",
      "destination": "https://shotcount-web.dosudavy.workers.dev/apple-touch-icon-v2.png"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
