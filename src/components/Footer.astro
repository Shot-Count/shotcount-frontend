---
import Logo from "@/assets/logo-black.png";
import { APPCONFIG } from "@/utils/config";
import { Image } from "astro:assets";
---

<footer
  class="bg-[#F1F2F4] text-black w-full h-max flex flex-col md:items-start items-center gap-5 md:px-24.5 pt-9 md:pb-2 pb-4"
>
  <figure class="flex flex-col md:items-start items-center gap-5">
    <Image
      loading={"lazy"}
      src={Logo}
      class="max-w-31.5"
      alt="ShotCount Logo"
    />
    <p>Download Shot Count</p>
    <div class="flex md:flex-row flex-col items-center gap-4">
      <a
        href={APPCONFIG.APP_URL.APP_STORE}
        class="bg-foreground text-white rounded-lg gap-1 p-2 px-3 font-semibold font-inter flex-center"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          ><path
            fill="currentColor"
            d="M17.05 20.28c-.98.95-2.05.8-3.08.35c-1.09-.46-2.09-.48-3.24 0c-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8c1.18-.24 2.31-.93 3.57-.84c1.51.12 2.65.72 3.4 1.8c-3.12 1.87-2.38 5.98.48 7.13c-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25c.29 2.58-2.34 4.5-3.74 4.25"
          ></path></svg
        >
        Get on the App Store</a
      >
      <a
        href={APPCONFIG.APP_URL.PLAY_STORE}
        class="bg-foreground text-white rounded-lg gap-1 p-2 px-3 font-semibold font-inter flex-center"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          ><path
            fill="currentColor"
            d="m3.637 3.434l8.74 8.571l-8.675 8.65a2.1 2.1 0 0 1-.326-.613a2.5 2.5 0 0 1 0-.755V4.567c-.026-.395.065-.79.26-1.133m12.506 4.833l-2.853 2.826L4.653 2.6c.28-.097.58-.124.873-.078c.46.126.899.32 1.302.573l7.816 4.325c.508.273 1.003.56 1.498.847M13.29 12.93l2.839 2.788l-2.058 1.146l-6.279 3.49c-.52.287-1.042.561-1.55.874a1.8 1.8 0 0 1-1.472.195zm7.36-.925a1.92 1.92 0 0 1-.99 1.72l-2.346 1.302l-3.087-3.022l3.1-3.074c.795.443 1.577.886 2.358 1.303a1.89 1.89 0 0 1 .964 1.771"
          ></path></svg
        >
        Get on Play Store</a
      >
    </div>
  </figure>

  <hr class="w-[80%] md:w-full bg-none border-[#C7D1DB] md:mt-0 mt-6" />

  <div
    class="flex items-center justify-between md:flex-row w-full flex-col gap-4"
  >
    <p>
      &copy; Copyright {new Date().getFullYear()}, All rights reserved
    </p>
    <figure class="flex-center gap-4">
      <a href={APPCONFIG.SOCIALS.LINKEDIN} target="_blank" rel="noopener" title="Go to Linkedin Page"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          ><path
            fill="currentColor"
            d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"
          ></path></svg
        ></a
      >
      <a  href={APPCONFIG.SOCIALS.INSTAGRAM} target="_blank" rel="noopener" title="Go to Instagram Page"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          ><path
            fill="currentColor"
            d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4zm9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8A1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5a5 5 0 0 1-5 5a5 5 0 0 1-5-5a5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3"
          ></path></svg
        ></a
      >
      <a  href={APPCONFIG.SOCIALS.twitter} target="_blank" rel="noopener" title="Go to Twitter Page"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 512 512"
          ><path
            fill="currentColor"
            d="M389.2 48h70.6L305.6 224.2L487 464H345L233.7 318.6L106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9zm-24.8 373.8h39.1L151.1 88h-42z"
          ></path></svg
        ></a
      >
    </figure>
  </div>
</footer>
