---
import sectionImg from "@/assets/building.jpg";
import { Tabs } from "@/utils/config";
import { Image } from "astro:assets";
---

<section
  class="w-full min-h-screen 2xl:min-h-auto 2xl:gap-30 flex flex-col px-2 gap-10 items-center justify-between"
>
  <h1
    class="text-center font-cunia uppercase text-foreground text-4xl lg:text-7xl"
  >
    We’re Building for High-Variance Operators
  </h1>

  <div
    class="w-full lg:h-[496px] flex flex-col gap-6 bg-offWhite rounded-2xl py-20 md:py-5 px-6 md:flex-row items-center justify-between!"
  >
    <aside class="flex flex-col items-start gap-8">
      <ul class="bg-accent rounded-full relative flex-center gap-5 p-2">
        <div id="selector" class="h-[90%] absolute rounded-full bg-white"></div>
        {
          Tabs.map((el) => (
            <li
              class={`cursor-pointer tab-item z-10 text-[#22272B] md:text-base rounded-full shrink-0 py-3 capitalize px-5`}
            >
              {el.title}
            </li>
          ))
        }
      </ul>
      <h3
        id="section-title"
        class="font-bold font-open shrink-0 leading-none text-2xl lg:text-[40px] text-[#44546F]"
      >
        Founders expanding investor and partnership reach.
      </h3>
    </aside>
    <figure
      class="lg:w-[550px] w-full md:aspect-auto aspect-square shrink-0 lg:h-[440px] rounded-lg overflow-hidden relative"
    >
      <Image
        id="section-image"
        src={sectionImg}
        class={"object-cover w-full h-full "}
        alt={"founders_image"}
      />
    </figure>
  </div>
</section>

<script>
  import("../scripts/Tabswitch.js").then(({ TabSwitcher }) => TabSwitcher());
</script>
