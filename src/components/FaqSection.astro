---

const faqs = [
  {
    question: "What is ShotCount?",
    answer:
      "ShotCount helps you take more shots — and learn from every one. It’s an AI app that helps you turn rejection into feedback, grow your confidence, and increase your success rate over time.",
  },
  {
    question: "Why focus on rejection?",
    answer:
      "Because rejection is proof that you’re trying. Every “no” holds information you can use to get better. We built ShotCount to help you extract that signal and turn effort into progress.",
  },
  {
    question: "Do I need to upload screenshots?",
    answer:
      "No — that’s optional. But if you do, the AI can analyze tone and structure to give clearer, more specific feedback.",
  },
  {
    question: "What kind of feedback will I get?",
    answer:
      "Actionable insights you can use immediately—what to reword, when to follow up, and how to communicate more effectively next time.",
  },
  {
    question: "Who is it for?",
    answer:
      "Anyone who takes shots in the real world — founders, job seekers, salespeople, creators. If your goals depend on putting yourself out there, ShotCount is built for you.",
  },
  {
    question: "Can it help me win faster?",
    answer:
      "That’s exactly the goal. The more shots you take and track, the faster you learn what works. We built ShotCount to help you stay consistent, learn quickly, and win more often.",
  },
  {
    question: "How private is my data?",
    answer:
      "Completely private. Your messages and screenshots are encrypted, never shared, and never used to train outside models.",
  },
  {
    question: "Why is it paid?",
    answer:
      "Because we’re building for people who take their growth seriously. There’s no free tier, no ads, and no noise — just clear, focused improvement.",
  },
  {
    question: "How much does it cost?",
    answer:
      "$9.99/month for individuals. $39.99/month for teams. Each plan gives full access to the app, AI feedback, and analytics.",
  },
  {
    question: "When will it be available?",
    answer:
      "We’re still building the first version. You can join the waitlist now, and we’ll notify you as soon as early access opens.",
  },
];

---

<section id="faq" class="w-full flex px-4 flex-col mt-10 items-center gap-10 md:gap-20">
  <h1 class="text-center font-cunia uppercase text-foreground text-4xl md:text-7xl">
    Everything You Need to Know.
  </h1>

  <ul class="lg:max-w-3xl max-w-2xl w-full flex flex-col items-center gap-6">
    {faqs.map((el, i) => (
      <li
        class="faq-item w-full bg-[#F6F3F2] rounded-2xl cursor-pointer py-4 h-max px-8 overflow-hidden transition-all"
        data-index={i}
      >
        <div class="flex items-center justify-between">
          <p class="font-inter text-foreground font-medium md:text-lg">{el.question}</p>
          <svg
            class="faq-icon transition-transform duration-200"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path
              fill="currentColor"
              d="M18 12.998h-5v5a1 1 0 0 1-2 0v-5H6a1 1 0 0 1 0-2h5v-5a1 1 0 0 1 2 0v5h5a1 1 0 0 1 0 2"
            />
          </svg>
        </div>
        <p class="faq-answer text-gray-600 md:text-base max-h-0 opacity-0 mt-0">
          {el.answer}
        </p>
      </li>
    ))}
  </ul>
</section>

<script>
import("../scripts/faq.js").then(({ setupFAQ }) => setupFAQ());
</script>
