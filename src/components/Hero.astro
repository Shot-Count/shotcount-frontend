---
import { Image } from "astro:assets";
import MockupImage from "@/assets/mockup.png";
import Card from "./Card.astro";
---

<section id="hero" class="w-full flex flex-col 2xl:gap-40 overflow-x-hidden relative items-center justify-between min-h-screen 2xl:min-h-auto md:min-h-[700px] lg:min-h-screen ">
<article class="col-center text-center gap-9">
<h1 class="text-center font-cunia uppercase text-foreground text-4xl lg:text-7xl">LAND JOBS. <br />GET INTO GRAD SCHOOL.</h1>
<div class="col-center lg:p-0 p-4 text-base lg:text-sm 2xl:text-base gap-5">
    <p>ShotCount matches you with the right jobs and programs. <br />
Apply with AI, reach the right people, track every step, and follow up systematically.</p>

<button
  type="button"
  data-shotcount-auth-trigger="signin"
  class="bg-primary text-foreground p-2 rounded-lg ring-1 px-3 font-semibold cursor-pointer ring-primary"
>
  Try for free
</button>
</div>
</article>

<Card type="shots" />
<Card type="microsoft" />

<Image loading={"eager"} src={MockupImage} class={"max-w-55"} alt="Mockup of the shotCount app" />

</section>
