---
import logoImage from "@/assets/logo.svg";
import { Image } from "astro:assets";
---

<header class="flex items-center justify-between w-full pt-10 px-4 lg:px-10 relative">
  <figure class="absolute w-max">
    <Image loading="eager" src={logoImage} class={"lg:max-w-none max-w-28"} alt="ShotCount Logo" />
  </figure>

  <nav class="hidden lg:flex justify-center w-full gap-12 text-black font-medium">
    <a href="#howitworks">How it works</a>
    <a href="#philosophy">Philosophy</a>
    <a href="#team">Team</a>
    <a href="#faq">FAQ</a>
  </nav>

  <button
    type="button"
    data-shotcount-auth-trigger="signin"
    class="hidden lg:inline-flex ml-auto items-center rounded-full border border-black/12 bg-white px-5 py-2.5 text-sm font-semibold text-foreground transition hover:bg-offWhite"
  >
    Sign in with Google
  </button>

  <button id="opennav" class="md:hidden flex ml-auto">
    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24"><path fill="currentColor" d="M4 18q-.425 0-.712-.288T3 17t.288-.712T4 16h16q.425 0 .713.288T21 17t-.288.713T20 18zm0-5q-.425 0-.712-.288T3 12t.288-.712T4 11h16q.425 0 .713.288T21 12t-.288.713T20 13zm0-5q-.425 0-.712-.288T3 7t.288-.712T4 6h16q.425 0 .713.288T21 7t-.288.713T20 8z"/></svg>
  </button>
</header>

<script>
  window.addEventListener("DOMContentLoaded", async () => {
    const { toggleMobileNav } = await import("../scripts/nav.js");
    const openBtn = document.querySelector("#opennav");

    openBtn?.addEventListener("click", () =>
      toggleMobileNav("#nav", "#nav-list a", "open")
    );
  });
</script>
